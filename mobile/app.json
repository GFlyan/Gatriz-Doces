{
  "expo": {
    "name": "Gatriz Doces",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-gatriz.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.gatrizdoces.android",
      "adaptiveIcon": {
        "backgroundColor": "#CD9D86",
        "foregroundImage": "./assets/images/logo-gatriz.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-gatriz.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-gatriz.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#CD9D86",
          "dark": {
            "image": "./assets/images/logo-gatriz.png",
            "backgroundColor": "#CD9D86"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps._some_id_here_"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "95aaa9d2-5a15-43f4-a022-376567845c9d"
      }
    },
    "owner": "flyan"
  }
}
